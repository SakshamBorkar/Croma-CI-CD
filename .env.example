# ─────────────────────────────────────────────────────────────────
# Croma CI Platform — Environment Variables
# Copy this to .env and fill in values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000", "https://croma-ci.vercel.app"]

# ── Ollama (local LLM — no API key needed) ────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=mistral          # or: llama3, llama3.1, gemma2, phi3
OLLAMA_EMBED_MODEL=nomic-embed-text  # or: mxbai-embed-large, all-minilm
OLLAMA_TEMPERATURE=0.1
OLLAMA_MAX_TOKENS=2000

# ── ChromaDB (local vector store) ────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_PREFIX=croma_ci

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://croma:croma@localhost:5432/croma_ci

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
RAG_CACHE_TTL_SECONDS=86400

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_TO_SOMETHING_LONG_AND_RANDOM
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── RAG Pipeline ─────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RETRIEVE=20
TOP_K_RERANK=5
BM25_WEIGHT=0.4
DENSE_WEIGHT=0.6

# ── Scraping ─────────────────────────────────────────────────
SCRAPE_REQUEST_TIMEOUT=30
SCRAPE_CONCURRENCY=5

# ── Alerting ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
CHANGE_DETECTION_THRESHOLD=0.05
